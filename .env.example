# Copy to .env and fill in your keys. Never commit .env.

# --- On-chain / DEX ---
ETHERSCAN_API_KEY=
DUNE_API_KEY=
THE_GRAPH_API_KEY=

# --- Aggregate flow data ---
COINMETRICS_API_KEY=

# --- Vendor L2 CEX data (Tier A unlock) ---
# Set DATA_VENDOR to 'tardis' (default) or 'kaiko'
DATA_VENDOR=tardis
TARDIS_API_KEY=
KAIKO_API_KEY=

# --- Archive node (Uniswap exact block state, Phase 4) ---
ETH_ARCHIVE_RPC_URL=

# --- Tron USDT flows (Phase 6) ---
TRONGRID_API_KEY=
